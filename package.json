    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.20",
    "@cloudflare/workers-types": "^4.20260310.1",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  }
}
