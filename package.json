{
  "name": "blackroad-tools",
  "version": "1.0.0",
  "description": "BlackRoad OS Tools API - Agent orchestration, memory, reasoning, coordination",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
