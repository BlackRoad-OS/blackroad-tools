# Copy this file to .env and fill in with local/test credentials.
# Never commit the populated .env file – it should remain local only.

# Shared auth between your assistant and the adapter
TOOLS_TOKEN=change-me-long-random

# BlackRoad AI routing – @blackboxprogramming / @lucidia only
# Do NOT add keys for OpenAI, Anthropic, Groq, or any other third-party AI provider.
BLACKBOX_API_URL=https://api.blackboxai.io
BLACKBOX_API_KEY=
BLACKBOX_MODEL=blackbox-pro
LUCIDIA_API_URL=https://lucidia.ai/api
LUCIDIA_API_KEY=

# Tailscale (self-hosted mesh for Pi/infra access)
TAILSCALE_AUTH_KEY=
TAILSCALE_TAILNET=

# Outbound notification endpoints
CHANNEL_DEV_PRS=https://hooks.slack.com/services/xxx/yyy/zzz
CHANNEL_DEV_CI=https://hooks.slack.com/services/xxx/yyy/aaa
CHANNEL_RELEASES=https://discord.com/api/webhooks/xxx/yyy
CHANNEL_SECURITY=https://hooks.slack.com/services/xxx/yyy/bbb

# Task/portfolio service identifiers
ASANA_PROJECT_ID_MAIN=120xxxxxxxxxxxxx
ASANA_PROJECT_ID_OPS=120yyyyyyyyyyyyy
AIRTABLE_BASE_ID_MAIN=appxxxxxxxxxxxx
AIRTABLE_TABLE_BACKLOG=tblxxxxxxxxxxxx
GITLAB_GROUP=your-group
GITHUB_ORG=blackboxprogramming

# Secret values (use real tokens only in your private .env file)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/real/secret/value
ASANA_PAT=pat_xxxxx
AIRTABLE_API_KEY=key_xxxxx

# Git mirroring configuration
GITLAB_REPO_SSH=git@gitlab.com:group/project.git
GITLAB_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n....\n-----END OPENSSH PRIVATE KEY-----\n"

# Optional overrides
TOOLS_PORT=8787
PI_CORE_HOST=pi-core
